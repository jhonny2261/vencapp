{
  "name": "venccom",
  "version": "2.0.0",
  "description": "Control de Vencimientos — Sistema para supermercados y mini supers",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "licencia": "node generar_licencia.js",
    "empaquetar": "pkg server.js --targets node18-win-x64 --output dist/ControlVencimientos.exe --compress GZip",
    "lanzador": "pkg lanzador.js --targets node18-win-x64 --output dist/AbrirSistema.exe --compress GZip",
    "empaquetar-todo": "npm run empaquetar && npm run lanzador"
  },
  "bin": "server.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "core/**/*",
      ".env",
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "vencimientos",
    "inventario",
    "supermercado"
  ],
  "author": "Jhony Lorenzo",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "sql.js": "^1.12.0"
  }
}
